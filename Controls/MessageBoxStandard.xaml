<UserControl x:Class="PawaLite.Controls.MessageBoxStandard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             x:Name="RootControl" Visibility="Visible" Background="Transparent" 
             IsHitTestVisible="True" ClipToBounds="True">
    <Grid x:Name="RootGrid">
        <!-- The overlay background, just a note that it can stack when multiple controls are being spawned! (Needs CS logic fixing)-->
        <Border x:Name="OverlayBackground" Background="#000000" Opacity="0" Visibility="Collapsed"/>
        <Border x:Name="DialogBorder" MinWidth="660" MinHeight="185" ClipToBounds="True" MaxHeight="600" MaxWidth="800" Background="#080808" BorderBrush="#191919" BorderThickness="1.5" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="1" RenderTransformOrigin="0.5,0.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="75"/>
                </Grid.RowDefinitions>
                <Grid Margin="10,10,10,10" Grid.Row="0">
                    <Grid>
                        <Image x:Name="IconImage" Opacity="0.8" Width="34" Height="35" Margin="5,5,0,0" Source="/Resource/Sidebar/Brush_Themes-Paint.png" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <TextBlock x:Name="TitleText" VerticalAlignment="Top" Margin="49,10,7,0" FontFamily="Inter" Text="Theme Settings" FontSize="20" Foreground="White" Opacity="0.9" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="SubtitleText" VerticalAlignment="Top" Margin="49,50,15,20" FontFamily="Inter" FontSize="16" Text="This theme has special layout overrides. Do you want to apply them?" Foreground="White" Opacity="0.7" TextWrapping="Wrap"/>
                    </Grid>
                </Grid>
                <StackPanel x:Name="InputPanel" VerticalAlignment="Top" Margin="10,0,10,0" Grid.Row="1" Visibility="Collapsed">
                    <Border Background="#121418" BorderBrush="#2A2F38" BorderThickness="1.3" CornerRadius="8" Height="45">
                        <TextBox x:Name="InputBox" FontSize="18" Opacity="0.8" Text="aa" CaretBrush="White" Margin="8,12,8,12" Background="Transparent" Foreground="White" FontFamily="Inter" BorderThickness="0"/>
                    </Border>
                </StackPanel>

                <Border Height="60" Background="Transparent" VerticalAlignment="Bottom" CornerRadius="0,0,10,10" Margin="0,0,0,0" Grid.Row="2">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Height="45" VerticalAlignment="Bottom" Margin="0,0,20,10">
                        <Button x:Name="PrimaryButton" MinWidth="80" Height="39" Cursor="Hand" Content="Ok" Margin="0,0,10,0" Click="PrimaryButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="PART_Border" Background="Transparent" BorderBrush="#191919" BorderThickness="1.3" CornerRadius="5" Margin="0,0,0,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" TextElement.FontFamily="Inter" TextElement.FontSize="15" TextElement.Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="PART_Border" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="SecondaryButton" Height="39" MinWidth="78" Cursor="Hand" Content="No" Click="SecondaryButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="PART_Border" Background="Transparent" BorderBrush="#191919" BorderThickness="1.3" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" TextElement.FontFamily="Inter" TextElement.FontSize="15" TextElement.Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="PART_Border" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
