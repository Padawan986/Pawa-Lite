<UserControl x:Class="PawaLite.Controls.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto"
             MinHeight="120"
             Visibility="Visible"
             RenderTransformOrigin="0,0">

    <Border x:Name="RootBorder"
            Background="#080808"
            BorderBrush="#191919"
            BorderThickness="2"
            MinWidth="340"
            MinHeight="96"
            MaxWidth="650"
            CornerRadius="10"
            Opacity="0"
            Padding="14"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,10,10,0">

        <!-- Horizontal + Vertical transforms -->
        <Border.RenderTransform>
            <TransformGroup>
                <TranslateTransform x:Name="TranslateTransform" X="380" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect Color="Black"
                              BlurRadius="14"
                              ShadowDepth="0"
                              Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <!-- Close button -->
            <Button x:Name="CloseButton"
           Focusable="False"
           Style="{DynamicResource RoundedCloseButtonStylr}"
           Click="CloseButton_Click"
           Width="36"
           Height="28"
           HorizontalAlignment="Right"
           VerticalAlignment="Top"
           Background="Transparent"
           BorderThickness="0"
           ToolTip="Close" Margin="0,-16,-16,0">
                <TextBlock FontFamily="{StaticResource SegoeFluentIcons}"
                  FontSize="10"
                  Opacity="0.7"
                  Foreground="White"
                  Text="&#xE8BB;"/>
            </Button>


            <!-- Content -->
            <Grid Margin="0,6,32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image x:Name="IconImage"
           Width="42"
           Height="42"
           Margin="0,0,14,0"
           VerticalAlignment="Top"
           Opacity="0.85"
           RenderOptions.BitmapScalingMode="HighQuality"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock x:Name="TitleText"
                   Foreground="White"
                   FontFamily="{DynamicResource Inter}"
                    FontWeight="SemiBold"
                   FontSize="17"
                   Opacity="0.9"
                   TextWrapping="Wrap"
                   MaxWidth="600"
                   Margin="0,0,0,4"/>

                    <TextBlock x:Name="DescriptionText"
                   Foreground="White"
                   FontFamily="{DynamicResource Inter}"
                   FontSize="14.5"
                   FontWeight="Medium"
                   Opacity="0.55"
                   TextWrapping="Wrap"
                   MaxWidth="600"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
