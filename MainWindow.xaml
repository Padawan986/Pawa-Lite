<Window x:Class="PawaLite.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework" 
        xmlns:local="clr-namespace:PawaLite" 
        mc:Ignorable="d" 
        Title="Pawa" Background="#080808" 
        AllowsTransparency="False" WindowStartupLocation="CenterScreen" WindowStyle="None" Height="620" Width="920">

    <!--#region Window Resources-->
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Storyboard x:Key="CloseSettingsStoryboard">
            <DoubleAnimation Storyboard.TargetName="SettingsBackDrop" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsHostBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.18"/>
        </Storyboard>

        <Storyboard x:Key="OpenSettingsStoryboard">
            <DoubleAnimation Storyboard.TargetName="SettingsBackDrop" Storyboard.TargetProperty="Opacity" From="0" To="0.6" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsHostBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleX" From="0.94" To="1" Duration="0:0:0.18"/>
            <DoubleAnimation Storyboard.TargetName="SettingsScale" Storyboard.TargetProperty="ScaleY" From="0.94" To="1" Duration="0:0:0.18"/>
        </Storyboard>

        <Storyboard x:Key="OpenWelcomeStoryboard">
            <DoubleAnimation Storyboard.TargetName="WelcomeBackDrop" Storyboard.TargetProperty="Opacity" From="0" To="0.6" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="WelcomeBorderMessageHost" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleX" From="0.94" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleY" From="0.94" To="1" Duration="0:0:0.18" />
        </Storyboard>

        <Storyboard x:Key="CloseThemeStoryboard">
            <DoubleAnimation Storyboard.TargetName="ThemeBackdrop" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ThemeHostPrimary" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ThemeScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ThemeScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.18" />
        </Storyboard>

        <Storyboard x:Key="OpenThemeStoryboard">
            <DoubleAnimation Storyboard.TargetName="ThemeBackdrop" Storyboard.TargetProperty="Opacity" From="0" To="0.6" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ThemeHostPrimary" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ThemeScale" Storyboard.TargetProperty="ScaleX" From="0.94" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ThemeScale" Storyboard.TargetProperty="ScaleY" From="0.94" To="1" Duration="0:0:0.18" />
        </Storyboard>

        <Storyboard x:Key="CloseWelcomeStoryboard">
            <DoubleAnimation Storyboard.TargetName="WelcomeBackDrop" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="WelcomeBorderMessageHost" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="WelcomeScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.18" />
        </Storyboard>

    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0.5" ResizeBorderThickness="4" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!--#endregion-->

    <Grid x:Name="WindowCoreGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- region Titlebar -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Opacity="0" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="2" Grid.RowSpan="2"/>


        <Border x:Name="Titlebar" Grid.Row="0" Background="Transparent" MouseLeftButtonDown="ChromeDrag" BorderThickness="0">
            <Grid x:Name="Tilebarcontent">

                <StackPanel x:Name="TitleLeftSide" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Border x:Name="IconHost" Opacity="0.7" Margin="15,3,0,3">
                        <Image x:Name="VelIco" Source="/Resource/logo.ico" Height="25" Width="27" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <TextBlock x:Name="GreetingText" Text="Hello!" FontSize="13" FontFamily="{DynamicResource Inter}" Foreground="#AAAAAA" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel x:Name="TestMiddle" Visibility="Collapsed" HorizontalAlignment="Center"  Orientation="Horizontal">
                    <Border x:Name="HomeIconHost" CornerRadius="4" RenderOptions.BitmapScalingMode="HighQuality" Background="#12FFFFFF" Opacity="0.7" Margin="0,3,0,3">
                        <Image x:Name="HomeIcon" Source="/Resource/Sidebar/BoxCode.png" Margin="3" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border x:Name="ClientMagIconHost" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.7" Margin="10,3,0,3">
                        <Image x:Name="ClientIcon" Source="/Resource/Settings/Settings_Logging.png" Margin="3" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border x:Name="ChangelogsiconHost" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.7" Margin="10,3,0,3">
                        <Image x:Name="ChangeIcon" Source="/Resource/Sidebar/NewsHome.png" Margin="3" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Border x:Name="ThemeIconHost" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.7" Margin="10,3,0,3">
                        <Image x:Name="ThemeIcon" Source="/Resource/Sidebar/Brush_Themes-Paint.png" Margin="3" RenderOptions.BitmapScalingMode="HighQuality" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="45"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Border>
                    <Border x:Name="SettingsIconHost" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.7" Margin="10,3,0,3">
                        <Image x:Name="SettingsIcon" Source="/Resource/Bt/Cog_Settings-Fluent.png" Margin="3" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="VelVersionLocal" Visibility="Visible" ToolTip="Installed Pawa version" Text="0.0.0" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,0" FontFamily="{StaticResource Inter}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="16" Height="18" />

                <StackPanel x:Name="TitleRightSide" Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button x:Name="MinimizeButton" Focusable="False" Style="{DynamicResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="45" Height="30" Background="Transparent" BorderThickness="0" ToolTip="Minimize">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text="&#xE921;"/>
                    </Button>

                    <Button x:Name="MaximizeButton" Focusable="False" Style="{DynamicResource WindowControlButtonStyle}" Click="MaximizeButton_Click" Width="45" Height="30" Background="Transparent" BorderThickness="0" ToolTip="Maximize">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text="&#xE922;"/>
                    </Button>

                    <Button x:Name="CloseButton" Focusable="False" Style="{DynamicResource CloseButtonStyle}" Click="CloseButton_Click" Width="45" Height="30" Background="Transparent" BorderThickness="0" ToolTip="Close">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text="&#xE8BB;"/>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>

        <!-- #endregion-->

        <!--#region Main Content-->

        <Grid x:Name="MainGrid" ClipToBounds="True" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


                <Border x:Name="SidebarGlobal" BorderBrush="#1E1E1E" Visibility="Visible" BorderThickness="0,0,1,0" Background="#0C0C0C">
                <Grid>
                    <StackPanel VerticalAlignment="Bottom">

                        <Button x:Name="AppearanceButton" Height="60" Focusable="False" Click="OpenTheme_Click" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource HoverOpacityButton}" Background="Black" Margin="0,0,0,0">
                            <Image Source="/Resource/Sidebar/Brush_Themes-Paint.png" RenderOptions.BitmapScalingMode="HighQuality" Height="29" Width="45" RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="45"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Image.RenderTransform>
                            </Image>
                        </Button>

                        <Button x:Name="SettingsButton" Height="60" Focusable="False" Click="OpenSettings_Click" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource HoverOpacityButton}" Background="Black" Margin="0,0,0,0">
                            <Image Source="/Resource/Bt/Cog_Settings-Fluent.png" RenderOptions.BitmapScalingMode="HighQuality" Height="24" Width="28"/>
                        </Button>

                    </StackPanel>

                    <StackPanel VerticalAlignment="Top">

                        <Border x:Name="HomeButton" Height="50" Width="60" Background="Transparent" Cursor="Hand" MouseDown="HomeButton_MouseLeftButtonDown" MouseEnter="HomeButton_MouseEnter" MouseLeave="HomeButton_MouseLeave">
                            <Grid>
                                <Border x:Name="BlueBarHome" Width="3" Background="#2D7DFF" Opacity="0" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleY="0"/>
                                    </Border.RenderTransform>
                                </Border>
                                <Border x:Name="BlueBarHomeFullyFilled" Width="3" Background="#2D7DFF" Visibility="Collapsed" HorizontalAlignment="Left"/>
                                <Image Source="/Resource/Sidebar/BoxCode.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.5" Margin="16,12,16,12"/>
                            </Grid>
                        </Border>

                        <Border x:Name="CloudButton" Height="50" Width="60" Background="Transparent" Cursor="Hand" MouseDown="CloudButton_MouseLeftButtonDown" MouseEnter="CloudButton_MouseEnter" MouseLeave="CloudButton_MouseLeave">
                            <Grid>
                                <Border x:Name="BlueBarCloud" Width="3" Background="#2D7DFF" Opacity="0" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleY="0"/>
                                    </Border.RenderTransform>
                                </Border>
                                <Border x:Name="BlueBarCloudFullyFilled" Width="3" Background="#2D7DFF" Visibility="Collapsed" HorizontalAlignment="Left"/>
                                <Image Source="/Resource/Settings/Settings_Logging.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.5" Margin="16,12,16,12"/>
                            </Grid>
                        </Border>

                        <Border x:Name="ScriptButton" Visibility="Collapsed" Height="50" Width="60" Background="Transparent" Cursor="Hand" MouseDown="ScriptButton_MouseLeftButtonDown" MouseEnter="ScriptButton_MouseEnter" MouseLeave="ScriptButton_MouseLeave">
                            <Grid>
                                <Border x:Name="BlueBarScripts" Width="3" Background="#2D7DFF" Opacity="0" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleY="0"/>
                                    </Border.RenderTransform>
                                </Border>
                                <Border x:Name="BlueBarScriptsFullyFilled" Width="3" Background="#2D7DFF" Visibility="Collapsed" HorizontalAlignment="Left"/>
                                <Image Source="/Resource/Sidebar/PkgVelocity.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.5" Margin="16,12,16,12"/>
                            </Grid>
                        </Border>

                        <Border x:Name="ChangeLogsNewsButton" Height="50" Width="59" Background="Transparent" Cursor="Hand" MouseDown="ChangeLogsNewsButton_MouseLeftButtonDown" MouseEnter="ChangeLogsNewsButton_MouseEnter" MouseLeave="ChangeLogsNewsButton_MouseLeave">
                            <Grid>
                                <Border x:Name="BlueBarNewsChangeLogs" Width="3" Background="#2D7DFF" Opacity="0" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleY="0"/>
                                    </Border.RenderTransform>
                                </Border>
                                <Border x:Name="BlueBarNewsChangeLogsFullyFilled" Width="3" Background="#2D7DFF" Visibility="Collapsed" HorizontalAlignment="Left"/>
                                <Image Source="/Resource/Sidebar/NewsHome.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.5" Margin="17,13,17,13"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="PrimaryHost" Grid.Column="1" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" MinWidth="5"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="ExplorerBorder" Grid.Column="0" Margin="0" CornerRadius="0" Background="Transparent" BorderThickness="0">
                    <Grid>
                        <ListBox x:Name="ExplorerListBox" Focusable="False" SelectionChanged="ExplorerListBox_SelectionChanged" PreviewMouseRightButtonDown="ExplorerListBox_PreviewMouseRightButtonDown" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource ExplorerTreeListBoxStyle}" Margin="0,38,0,0">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Margin" Value="0,13,0,0" />
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid Margin="18.4,0,0,8.4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White" Opacity="0.5" FontSize="12.6" FontFamily="{StaticResource Inter}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                        </ListBox>
                        <Border Height="38" VerticalAlignment="Top" BorderBrush="#191919" BorderThickness="0,0,0,1.3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="38">
                                    <Image Source="/Resource/Exp/Search.png" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.5" HorizontalAlignment="Left" Width="20" Height="20" Margin="10,0,0,0"/>
                                    <TextBox x:Name="SearchTextBoxExp" TextChanged="SearchTextBox_TextChanged" Background="Transparent" FontFamily="{StaticResource Inter}" FontSize="15" CaretBrush="White" Foreground="White" Opacity="0.7" BorderThickness="0" BorderBrush="Transparent" VerticalAlignment="Center" Margin="40,0,0,0" HorizontalAlignment="Stretch">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                                <TextBlock x:Name="SettingsSearchPlaceholder" FontFamily="{StaticResource Inter}" Text="Search Explorer.." FontStyle="Italic" Foreground="White" Opacity="0.4" IsHitTestVisible="False" Margin="2,0,0,0" VerticalAlignment="Center" Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>

                                <Button x:Name="ReloadExplroer" Click="ReloadExplroer_Click" Focusable="False" Style="{StaticResource HoverOpacityButton}" Grid.Column="1" VerticalAlignment="Top" Margin="0,5,10,0" Width="28" Height="28" ToolTip="Refresh">
                                    <Image x:Name="ReloadImage" Source="/Resource/Exp/FluentRefresh.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20" Margin="0" RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <RotateTransform Angle="0"/>
                                        </Image.RenderTransform>
                                    </Image>
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

                <Border x:Name="Prim1aryHost" Grid.Column="2" Margin="0" CornerRadius="0" Background="#080808">
                    <Grid x:Name="PrimaryHostInside">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="170" MinHeight="40"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="BottomHostTerminal" Grid.Row="2" CornerRadius="10" Background="#0E0E0E" BorderThickness="1" BorderBrush="#1A1A1A" Margin="8,4,8,8">
                            <Grid>
                                <!--#region  Button Host-->

                                <Border x:Name="ButtonControlPrimary" Height="40" VerticalAlignment="Top" CornerRadius="10,10,0,0" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                                    <Grid Margin="5,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="ExecuteButton" Focusable="False" Grid.Column="0" Click="ExecuteButton_Click" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                            <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/RunFileExe.png" Width="18" Height="18" Margin="0,0,5,0"/>
                                                <TextBlock x:Name="ExecuteButtonText" Text="Execute" FontFamily="{StaticResource Inter}" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Click="ClearButton_Click" Focusable="False" Grid.Column="1" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                            <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/Clear.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="ClearButtonText" Text="Clear" VerticalAlignment="Center" FontFamily="{StaticResource Inter}" Foreground="#CCCCCC"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Click="OpenButton_Click" Focusable="False" Grid.Column="2" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                            <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/OpenFile.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="OpenButtonText" Text="Open" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Click="SaveButton_Click" Focusable="False" Grid.Column="3" Style="{StaticResource WebIconButtonStyle}" Margin="10">
                                            <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Resource/Bt/SaveFile.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="SaveButtonText" Text="Save" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Focusable="False" Grid.Column="6" Style="{StaticResource WebIconButtonStyle}" Click="InjectButton_Click" Margin="10">
                                            <StackPanel Orientation="Horizontal" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image Source="/Resource/Bt/Inject1.png" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="InjectButtonText" Text="Inject" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                            </StackPanel>
                                        </Button>

                                    </Grid>
                                </Border>

                                <!--#endregion-->

                                <!--#region Terminal Section -->

                                <Border Margin="0,40,0,0">
                                    <Grid x:Name="TerminalGridParent">

                                        <RichTextBox x:Name="TerminalBox" Focusable="False" IsDocumentEnabled="True" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" FontFamily="{StaticResource JetBrainsMono}" FontSize="14" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Margin="3,33,0,0"/>

                                        <TextBlock x:Name="Output_TerminalTitle" Text="Output" Foreground="White" FontWeight="Medium" Opacity="0.7" FontFamily="{StaticResource Inter}" FontSize="17" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,9,0,0"/>

                                        <Button x:Name="SaveTerminalButton" Focusable="False" Style="{StaticResource HoverOpacityButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,6,0" Width="28" Height="28" Click="SaveTerminalOutput_Click">
                                            <Image Source="/Resource/Bt/SaveFile.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20"/>
                                        </Button>

                                        <Button x:Name="ClearTerminalButton" Focusable="False" Style="{StaticResource HoverOpacityButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,72,0" Width="28" Height="28" Click="ClearTerminal_Click">
                                            <Image Source="/Resource/Bt/Clear.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20"/>
                                        </Button>

                                        <Button x:Name="CopyTerminalButton" Focusable="False" Style="{StaticResource HoverOpacityButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,39,0" Width="28" Height="28" Click="CopyTerminalOutput_Click">
                                            <Image Source="/Resource/Bt/Copy_Term.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" Height="20"/>
                                        </Button>

                                    </Grid>
                                </Border>

                                <!--#endregion-->

                            </Grid>
                        </Border>

                        <!--#region Editor Section -->

                        <GridSplitter Grid.Row="1" Height="5" Background="Transparent" HorizontalAlignment="Stretch" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Cursor="SizeNS"/>


                        <Border x:Name="EditorControl" CornerRadius="10" Background="#0E0E0E" BorderThickness="1" BorderBrush="#1A1A1A" Margin="8,8,8,4">
                            <Grid>
                                <local:EditorTabControl x:Name="TabCtrl" Background="Transparent" BorderThickness="0" Style="{DynamicResource Tabs}" />

                                <StackPanel x:Name="EmptyStatePanel" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock x:Name="EditorEmpty_textNoticeTitle" Text="You currently don't have any script tabs opened!" Foreground="White" FontSize="20" FontFamily="{StaticResource Inter}" FontWeight="SemiBold" Opacity="0.7" TextAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="EditorEmpty_textNoticeDesc" Text="Click the '+' in the top right to get started" Foreground="White" FontSize="13" FontFamily="{StaticResource Inter}" Opacity="0.45" TextAlignment="Center"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                        <!--#endregion-->

                    </Grid>
                </Border>

            </Grid>

            <Grid x:Name="ChangeLogHost" Visibility="Collapsed" Grid.Column="1" Background="#080808">
                <Border Height="40" VerticalAlignment="Top" BorderBrush="#191919" BorderThickness="0,0,0,1.2">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock x:Name="ChangeLogsSection_TitleTop" Foreground="White" FontFamily="{DynamicResource Inter}" Text="Changelogs" FontSize="17" Opacity="0.8" FontWeight="Medium" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">

                            <Button x:Name="ReloadExplorer" Click="ReloadExplorer_Click" Focusable="False" Style="{StaticResource HoverOpacityButton}" VerticalAlignment="Center" Width="28" Height="28" ToolTip="Refresh">
