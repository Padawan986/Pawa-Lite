                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Vertical" Margin="10,0" VerticalAlignment="Center" Grid.Column="0">
                                                <TextBlock x:Name="EnableBackgroundTitle" Text="Enable Media-Background" Foreground="White" Opacity="0.8" FontSize="20" FontFamily="{DynamicResource Inter}"/>
                                                <TextBlock x:Name="EnableBackgroundDesc" Text="Enable a custom background image for the interface" Foreground="White" Opacity="0.5" FontSize="15" Margin="0,5,0,0" FontFamily="{DynamicResource Inter}"/>
                                            </StackPanel>

                                            <ToggleButton x:Name="ToggleEnableBackground" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,25,0" Checked="ToggleEnableBackground_Checked" Unchecked="ToggleEnableBackground_Unchecked"/>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="BackgroundUrlContainer" Background="Transparent" BorderBrush="#191919" BorderThickness="1.3" CornerRadius="10" Height="41" Margin="10,0,10,0" Opacity="1" Visibility="Visible">
                                        <Grid>
                                            <TextBox x:Name="BackgroundUrlTextBox" Margin="10,5,10,5" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Foreground="White" Opacity="0.7" CaretBrush="White" FontSize="15" VerticalContentAlignment="Center" TextChanged="BackgroundUrlTextBox_TextChanged">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Grid>
                                                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                                                        <TextBlock x:Name="BackgroundUrlPlaceholder" Text="Enter Image URL" FontStyle="Italic" Foreground="White" Opacity="0.3" IsHitTestVisible="False" Margin="2,0,0,0" VerticalAlignment="Center" Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}" FontFamily="{DynamicResource Inter}"/>
                                                                    </Grid>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Image Transparency Slider (new row 3) -->
                                <Grid Grid.Row="4" Margin="10,20,0,10" Height="60">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Grid.Column="0" Margin="10,0">
                                        <TextBlock x:Name="ImageTransparencyTitle" Text="Image Transparency" Foreground="White" Opacity="0.8" FontSize="20" FontFamily="{DynamicResource Inter}"/>
                                        <TextBlock x:Name="ImageTransparencyDesc" Text="Adjust the background image transparency" Foreground="White" Opacity="0.5" FontSize="15" Margin="0,5,0,0" FontFamily="{DynamicResource Inter}"/>
                                    </StackPanel>

                                    <Slider x:Name="ImageTransparencySlider" Minimum="0" Maximum="0.55" Value="0.3" HorizontalAlignment="Right" TickFrequency="0.01" Width="150" VerticalAlignment="Center" Margin="553,0,10,0" ValueChanged="ImageTransparencySlider_ValueChanged" Grid.ColumnSpan="2" >
                                        <Slider.Template>
                                            <ControlTemplate TargetType="Slider">
                                                <Grid>
                                                    <Border Height="6" Background="#3d3d4a" VerticalAlignment="Center" CornerRadius="3"/>
                                                    <Border x:Name="PART_SelectionRange" Height="6" Background="#4d90fe" VerticalAlignment="Center" CornerRadius="3"/>
                                                    <Track x:Name="PART_Track" Margin="0" VerticalAlignment="Center">
                                                        <Track.Thumb>
                                                            <Thumb Width="14" Height="14">
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Ellipse Fill="#4d90fe"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Slider.Template>
                                    </Slider>

                                    <TextBlock x:Name="ImageTransparencyValue" Text="{Binding ElementName=ImageTransparencySlider, Path=Value, StringFormat={}{0:P0}}"  Foreground="White" Opacity="0.7" VerticalAlignment="Center" FontSize="14" Margin="10,0" Grid.Column="2" FontFamily="{DynamicResource Inter}"/>

                                    <Button x:Name="ResetImageTransparencyButton" Content="Reset" FontFamily="{DynamicResource Inter}" FontWeight="SemiBold" FontSize="13"  Style="{DynamicResource InteractiveBorderButtonStyle}" Padding="8,2"  Click="ResetImageTransparencyButton_Click" Background="#2d2d3a" Foreground="White" BorderBrush="#3d3d4a" BorderThickness="1"  Cursor="Hand" VerticalAlignment="Center" Margin="10,0,10,0" Grid.Column="3"/>
                                </Grid>

                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="WelcomeMessage" Visibility="Collapsed" Grid.RowSpan="2">
            <Grid>
                <Border x:Name="WelcomeBackDrop" Background="Black" Opacity="0.6" />

                <Border x:Name="WelcomeBorderMessageHost" Margin="60" Background="#080808" CornerRadius="10" BorderBrush="#191919" BorderThickness="2" Padding="20" HorizontalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="WelcomeScale" ScaleX="0.94" ScaleY="0.94" />
                    </Border.RenderTransform>

                    <Grid Margin="0,0,-12,-12">
                        <TextBlock FontFamily="{StaticResource Inter}" FontSize="20" FontWeight="SemiBold" Foreground="White" Opacity="1" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"> <Run Text="Hey " /><Run Text="{x:Static sys:Environment.UserName}" /><Run Text=", welcome to Pawa!" />
                        </TextBlock>

                        <TextBlock Text="Pawa now features a better and more lightweight user interface with improved performance and stability" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.6" TextWrapping="Wrap" Height="45" Width="577" Margin="10,65,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <TextBlock Text="Ui updates and fixes:" FontFamily="{StaticResource Inter}" FontSize="18" FontWeight="Medium" Foreground="White" Opacity="0.9" TextWrapping="Wrap" Height="25" Width="460" Margin="10,137,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <TextBlock Text="[+] Complete new layout and feel of the Ui" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Width="460" Margin="10,174,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <TextBlock Text="[+] Switched to WebView for better performance" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Width="460" Margin="10,204,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <TextBlock Text="[+] Client manager has been simplified and automatic client selection has made its way to Pawa! (Of course optional)" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Margin="10,234,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <TextBlock Text="[+] Added Auto-Inject and other cool Ui-related settings" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Normal" Foreground="White" Opacity="0.5" TextWrapping="Wrap" Height="20" Margin="10,264,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <Image Source="/Resource/logo.ico" Height="80" Width="80" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,10,10,0" />
                        <TextBlock Text="Simply Press 'Continue' to close this pop-up and enter Pawa!" FontFamily="{StaticResource Inter}" FontSize="16" FontWeight="Medium" Foreground="White" Opacity="0.8" TextWrapping="Wrap" Height="20" Margin="10,309,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <Button Style="{DynamicResource HoverOpacityButton}" FontFamily="{StaticResource Inter}" FontSize="15" FontWeight="Medium" ToolTip="Enter Pawa" Content="Continue" Foreground="White" Click="ContinueButton_Click" Height="40" Width="90" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="RenamePopup" Panel.ZIndex="2" Visibility="Collapsed" Grid.RowSpan="2">
            <Grid>
                <Border x:Name="ShadowBlockRenameTab" Opacity="0.5" Background="Black"/>

                <Border x:Name="CoreBorderRename" Visibility="Collapsed" ClipToBounds="True" Height="215" Width="460" Background="#080808" BorderBrush="#191919" BorderThickness="2" CornerRadius="10">
                    <Grid>

                        <StackPanel Height="58" VerticalAlignment="Top" Margin="10,10,10,0">
                            <Grid>
                                <Image Opacity="0.8" Source="/Resource/Tabs/Menu/Tab_Rename.png" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Left" Margin="7,8,0,9" Width="55"/>
                                <TextBlock VerticalAlignment="Top" Margin="70,15,0,0" FontFamily="Inter" FontSize="18" Foreground="White" Opacity="0.8" Text="Rename Tab"/>
                                <TextBlock VerticalAlignment="Top" Margin="70,40,0,0" FontFamily="Inter" FontSize="14" Foreground="White" Opacity="0.5" Text="Enter the new name below into the box and press 'Ok'."/>
                            </Grid>
                        </StackPanel>

                        <!-- TextBox -->
                        <StackPanel Height="50" VerticalAlignment="Top" Margin="10,85,10,0">
                            <Grid>
                                <Border Background="#080808" BorderBrush="#191919" BorderThickness="2" Height="45" CornerRadius="8">
                                    <TextBox x:Name="RenameTabTextBox" CaretBrush="White" Margin="8,12,8,12" Background="Transparent" Foreground="White" FontFamily="Inter" FontSize="16" Opacity="0.8" BorderThickness="0" />
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Bottom buttons -->
                        <Border x:Name="BottomBorderTabRename" Height="50" VerticalAlignment="Bottom" Margin="5,0,0,5" Background="Transparent">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Height="40" VerticalAlignment="Bottom" Margin="0,0,20,10">
                                    <!-- Ok Button -->
                                    <Button Width="65" Height="30" Click="CancelButton_Click" Cursor="Hand" Content="Cancel" FontFamily="{DynamicResource Inter}" FontSize="15" FontWeight="Medium" Margin="0,0,10,0" Style="{DynamicResource HoverOpacityButton}" Foreground="White"/>
                                    <Button Width="65" Height="30" Click="OkButton_Click" Cursor="Hand" Content="Ok" FontFamily="{DynamicResource Inter}" FontSize="15" FontWeight="Medium" Margin="0,0,7,0" Style="{DynamicResource HoverOpacityButton}" Foreground="White"/>

                                    <!-- Cancel Button -->
                                </StackPanel>

                                <Grid Visibility="Collapsed" HorizontalAlignment="Left" Height="40" VerticalAlignment="Bottom" Margin="10,0,20,10">

                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </Border>

        <Border x:Name="SplashScreen" Panel.ZIndex="1" Visibility="Collapsed" Grid.RowSpan="2">
            <Grid Background="#080808">
                <StackPanel x:Name="TitleRightSideSplashScreen" VerticalAlignment="Top" Orientation="Horizontal" HorizontalAlignment="Right" Panel.ZIndex="2">
                    <Button x:Name="SplashMinimize" Focusable="False" Style="{DynamicResource WindowControlButtonStyle}" Click="MinimizeButton_Click" Width="45" Height="30" Background="Transparent" BorderThickness="0" ToolTip="Minimize">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text="&#xE921;"/>
                    </Button>
                    <Button x:Name="SplashMaximize" Focusable="False" Style="{DynamicResource WindowControlButtonStyle}" Click="MaximizeButton_Click" Width="45" Height="30" Background="Transparent" BorderThickness="0" ToolTip="Maximize">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text="&#xE922;"/>
                    </Button>
                    <Button x:Name="SplashClose" Focusable="False" Style="{DynamicResource CloseButtonStyle}" Click="CloseButton_Click" Width="45" Height="30" Background="Transparent" BorderThickness="0" ToolTip="Close">
                        <TextBlock FontFamily="{StaticResource SegoeFluentIcons}" FontSize="10" Opacity="0.7" Foreground="White" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Made by Padawan985" FontSize="42" FontFamily="{DynamicResource Inter}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#444444"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="StatusBlockSplash" Text="" FontSize="16" FontFamily="{DynamicResource Inter}" Foreground="#888888" FontWeight="SemiBold" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="MessageBoxSpawnParent" Visibility="Visible" Panel.ZIndex="99" Grid.RowSpan="2"/>

    </Grid>
</Window>






